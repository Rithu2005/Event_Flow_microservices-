{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "panels": [
    {
      "title": "CPU Usage",
      "type": "timeseries",
      "datasource": "prometheus",
      "targets": [
        {
          "expr": "rate(container_cpu_usage_seconds_total{namespace='eventflow'}[5m])"
        }
      ]
    },
    {
      "title": "Memory Usage",
      "type": "timeseries",
      "datasource": "prometheus",
      "targets": [
        {
          "expr": "container_memory_usage_bytes{namespace='eventflow'}"
        }
      ]
    }
  ],
  "title": "EventFlow Overview"
}
